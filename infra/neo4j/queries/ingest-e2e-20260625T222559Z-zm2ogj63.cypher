ICONCEPT , ICUENTA , FVENC , AREND , CTITULOS , CTITASIG , FALTA FROM TITPRES WHERE IFOLPRES = :DCLTITPRES.IFOLPRES AND SVIGEN = :DCLTITPRES.SVIGEN EXEC SQL DECLARE TITPRES CURSOR FOR SELECT T1.IFOLPRES , T1.ICONCEPT , T1.ICUENTA , T1.FVENC , T1.AREND , T1.CTITULOS , T1.CTITASIG , T1.FALTA , T1.SVIGEN , T1.FREG , T1.IPROGRAM , T1.IUSUARIO , T1.ITERM , T2.ICUENTA , T2.SVIGEN , T2.IPERJUR , T2.ISUBCLAS , T2.NABREV , T2.ITIPOCTA , T2.IEMPR FROM TITPRES T1, CUENTA T2 WHERE T1.SVIGEN = \'A\' AND T1.ICONCEPT = :DCLTITPRES.ICONCEPT AND ( T1.CTITULOS - T1.CTITASIG ) > 0 AND T1.FVENC >= :WS-FEC-VEN-DB2 AND T1.FLIQUIDA = :DCLTITPRES.FLIQUIDA AND T1.AREND = :DCLTITPRES.AREND AND T2.IEMPR = :DCLCUENTA.IEMPR AND T1.ICUENTA = T2.ICUENTA ORDER BY T1.AREND, T1.FALTA, T1.IFOLPRES EXEC SQL DECLARE PERJUR CURSOR FOR SELECT T1.IFOLPRES , T1.ICONCEPT , T1.ICUENTA , T1.FVENC , T1.AREND , T1.CTITULOS , T1.CTITASIG , T1.FALTA , T1.SVIGEN , T2.SPERJUR , T3.ICUENTA , T3.SVIGEN , T3.IPERJUR , T3.ISUBCLAS , T3.IESTRATO , T3.NABREV , T3.ITIPOCTA , T3.IEMPR FROM TITPRES T1 , PERJUR T2 , CUENTA T3 WHERE T1.SVIGEN = \'A\' AND T1.ICONCEPT = :DCLTITPRES.ICONCEPT AND T1.SVIGEN = T3.SVIGEN AND T3.IEMPR = :DCLCUENTA.IEMPR AND T2.IPERJUR = T3.IPERJUR AND T2.ISUBCLAS = T3.ISUBCLAS AND T1.ICUENTA = T3.ICUENTA AND ( T1.CTITULOS - T1.CTITASIG ) > 0 AND T1.FVENC >= :WS-FEC-VEN-DB2 AND T1.FLIQUIDA = :DCLTITPRES.FLIQUIDA AND T1.AREND = :DCLTITPRES.AREND ORDER BY T1.AREND, T1.FALTA, T1.IFOLPRES EXEC SQL DECLARE SOLGRA CURSOR FOR SELECT ICUENTA , ICONCEPT , ICVEOPES , ITIPOSOL , IEMISORA , ISERIE , ICUPON , CTITULOS , MGTAORG , IFOLOPES , IFOLSOL , ISEC , IRELAC , SCASA , SESTATUS , FVENC , FSIST , IPROGRAM , IUSUARIO , ITERM FROM SOLGRAN WHERE IFOLOPES = :DCLSOLGRAN.IFOLOPES AND ITIPOSOL = \'CI\' EXEC SQL DECLARE CARPRO CURSOR FOR SELECT T1.ICUENTA , T1.IEMISORA , T1.ISERIE , T1.CTITEFE FROM CARTERA T1, AGPOCTA T2 WHERE T2.ICUENTA = T1.ICUENTA AND T1.ITIPOTEN IN (:DCLCARTERA.ITIPOTEN, :W000-ITIPOTEN-AUX ) AND T
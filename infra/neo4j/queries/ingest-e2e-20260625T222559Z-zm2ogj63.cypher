D T3.IEMPR = :DCLCUENTA.IEMPR AND T2.IPERJUR = T3.IPERJUR AND T2.ISUBCLAS = T3.ISUBCLAS AND T1.ICUENTA = T3.ICUENTA AND ( T1.CTITULOS - T1.CTITASIG ) > 0 AND T1.FVENC >= :WS-FEC-VEN-DB2 AND T1.FLIQUIDA = :DCLTITPRES.FLIQUIDA AND T1.AREND = :DCLTITPRES.AREND ORDER BY T1.AREND, T1.FALTA, T1.IFOLPRES EXEC SQL DECLARE SOLGRA CURSOR FOR SELECT ICUENTA , ICONCEPT , ICVEOPES , ITIPOSOL , IEMISORA , ISERIE , ICUPON , CTITULOS , MGTAORG , IFOLOPES , IFOLSOL , ISEC , IRELAC , SCASA , SESTATUS , FVENC , FSIST , IPROGRAM , IUSUARIO , ITERM FROM SOLGRAN WHERE IFOLOPES = :DCLSOLGRAN.IFOLOPES AND ITIPOSOL = \'CI\' EXEC SQL DECLARE CARPRO CURSOR FOR SELECT T1.ICUENTA , T1.IEMISORA , T1.ISERIE , T1.CTITEFE FROM CARTERA T1, AGPOCTA T2 WHERE T2.ICUENTA = T1.ICUENTA AND T1.ITIPOTEN IN (:DCLCARTERA.ITIPOTEN, :W000-ITIPOTEN-AUX ) AND T2.IGPOCTA = 140 ORDER BY T1.IEMISORA COPY DFHAID. COPY ZMGJ631. COPY ZMWSC010. COPY ZMWBV492. COPY ZMWSC011. COPY ZMWSC012. COPY ZMWSC013. COPY ZMWSC014. COPY ZMWSC017. 01 Z441-REGS. COPY ZMWLL441. 01 FL-FOLIO. COPY ZMWSR085. 01 CO-CAROPER. COPY ZMWSRA05. 01 CE-FECLOG. COPY ZMWSX090. 01 CE-FECHAB. COPY ZMWSX001. 01 CE-CENTRADO. COPY ZMWSR009. 01 EM-EMPRESA. COPY ZMWSZ403. 01 TR-TRANSFERENCIA. COPY ZMWSR432. 01 TI-PRESOL. COPY ZMWSRJ62. 01 AC-OPEINCC. COPY ZMWSRJ94. 01 AB-ABORTA. COPY ZMWSG532. 01 W1210-PZOLIQ PIC 9(03) VALUE 0. 01 W1220-PZOPRE PIC 9(05) VALUE 0. 01 W1200-MENSAJE. 05 W1200-TEXTO PIC X(43) VALUE \'F. VENCIMIENTO DEBE SER < F. AMORTIZACION: \'. 05 W1200-FECHA PIC X(10). 01 W1200-FVENC-AUX PIC X(10). 01 W1200-MENSAJE2. 05 W1200-TEXTO2 PIC X(25) VALUE \'FECHA NO MAYOR 96 HORAS: \'. 05 W1200-FECHA2 PIC X(10). 01 WM-MENSAJES. 03 WM-TECLA-INVALIDA PIC 9(04) VALUE 109. 03 WM-OPCION-INCORRECTA PIC 9(04) VALUE 110. 03 WM-INVALIDA-TRANSFER PIC 9(04) VALUE 584. 03 WM-SELECCIONE-OPCION PIC 9(04) VALUE 1095. COPY ZMWCOM11. 05 WC-CODIGO PIC 9(04) VALUE 0. 05 WC-COMANDO PIC X(10) VALUE SPACES. 05 WC-DATOS-PROCESO. 10 WC-ZMGJ631 PIC X(475) VALUE SPACES. 10 W
MERGE (n:Program {name: 'ECB250M'})
SET n += {description: 'Programa COBOL que generar archivo con movimientos mensuales y procuenta para estados de cuenta. ultima modificacion: jul/97 asateck (antonio urbano c.) se agruparon los ioperas a considerarse para grabar cargos, abonos, depositos, retiros, impuestos seleccionando los ioperas desde el cursor en base al grupo de operacion ==> cargos-abonos -- 107 depositos-retiros -- 108 impuestos -- 109. Pertenece a: PROBURSA S.A. DE C.V. 24/FEB/93. /.', ingestion: 'auto', layer: 'program', name: 'ECB250M', nodeType: 'program', objective: 'GENERAR ARCHIVO CON MOVIMIENTOS MENSUALES Y PROCUENTA PARA ESTADOS DE CUENTA. ULTIMA MODIFICACION: JUL/97 ASATECK (ANTONIO URBANO C.) SE AGRUPARON LOS IOPERAS A CONSIDERARSE PARA GRABAR CARGOS, ABONOS, DEPOSITOS, RETIROS, IMPUESTOS SELECCIONANDO LOS IOPERAS DESDE EL CURSOR EN BASE AL GRUPO DE OPERACION ==> CARGOS-ABONOS -- 107 DEPOSITOS-RETIROS -- 108 IMPUESTOS -- 109', reviewRequired: true, reviewSource: 'auto-ingestion', reviewStatus: 'pending_human_review', runId: 'e2e-20260621T203207Z-ecb220m-ecb230m-ecb240m-ecb250m-ecb255m-ecb270m-ecb280m-ecb290m-ecb300m-ecb320m', sourceFile: 'src/ECB250M.cbl', system: 'PROBURSA S.A. DE C.V. 24/FEB/93. /', viewTag: 'cobol-program'};

MERGE (n:Program {name: 'ECB255M'})
SET n += {description: 'Programa COBOL que generar resumen de movimientos de efectivo e impuestos para estados de cuenta. modifico : alejandro r. guiza maldonado fecha : diciembre/ 93 con este proceso se obtienen los movimientos de efectivo faltantes, por la incompatibilidad de periodos de estados de cuenta del sistema estadis. este programa sera ejecutado por dos procesos independientes diferenciandose estos por el para- metro de paso que contendra cada job siendo estos \'ec\' para estados de cuenta y \'se\' para proceso estadistico. ultima modificacion: jul/94 ing. allan fuentes tovar (hildebrando). se elimino el llenado de las columnas mdeposit y mretiro de la tabla eddepre. el calculo del saldo y los dias del mismo se realizara tanto para personas fisicas como para personas morales. ultima modificacion: mar/00 monica rubio (asateck). se modifico para que el iopera 1022 se reflejara en depo. y retiros de efectivo en la impresion del e.c. (abono por traspaso). ultima modificacion: dic/00 monica rubio (asateck).mrc se modifico la ocurrencia de 25 por 50 debido a que la tabla de ti0 (param).. Pertenece a: PROBURSA S.A. DE C.V. 30/ENE/93. /.', ingestion: 'auto', layer: 'program', name: 'ECB255M', nodeType: 'program', objective: 'GENERAR RESUMEN DE MOVIMIENTOS DE EFECTIVO E IMPUESTOS PARA ESTADOS DE CUENTA. MODIFICO : ALEJANDRO R. GUIZA MALDONADO FECHA : DICIEMBRE/ 93 CON ESTE PROCESO SE OBTIENEN LOS MOVIMIENTOS DE EFECTIVO FALTANTES, POR LA INCOMPATIBILIDAD DE PERIODOS DE ESTADOS DE CUENTA DEL SISTEMA ESTADIS. ESTE PROGRAMA SERA EJECUTADO POR DOS PROCESOS INDEPENDIENTES DIFERENCIANDOSE ESTOS POR EL PARA- METRO DE PASO QUE CONTENDRA CADA JOB SIENDO ESTOS \'EC\' PARA ESTADOS DE CUENTA Y \'SE\' PARA PROCESO ESTADISTICO. ULTIMA MODIFICACION: JUL/94 ING. ALLAN FUENTES TOVAR (HILDEBRANDO). SE ELIMINO EL LLENADO DE LAS COLUMNAS MDEPOSIT Y MRETIRO DE LA TABLA EDDEPRE. EL CALCULO DEL SALDO Y LOS DIAS DEL MISMO SE REALIZARA TANTO PARA PERSONAS FISICAS COMO PARA PERSONAS MORALES. ULTIMA MODIFICACION: MAR/00 MONICA RUBIO (ASATECK). SE MODIFICO PARA QUE EL IOPERA 1022 SE REFLEJARA EN DEPO. Y RETIROS DE EFECTIVO EN LA IMPRESION DEL E.C. (ABONO POR TRASPASO). ULTIMA MODIFICACION: DIC/00 MONICA RUBIO (ASATECK).MRC SE MODIFICO LA OCURRENCIA DE 25 POR 50 DEBIDO A QUE LA TABLA DE TI0 (PARAM).', reviewRequired: true, reviewSource: 'auto-ingestion', reviewStatus: 'pending_human_review', runId: 'e2e-20260621T203207Z-ecb220m-ecb230m-ecb240m-ecb250m-ecb255m-ecb270m-ecb280m-ecb290m-ecb300m-ecb320m', sourceFile: 'src/ECB255M.cbl', system: 'PROBURSA S.A. DE C.V. 30/ENE/93. /', viewTag: 'cobol-program'};

MERGE (n:Program {name: 'ECB270M'})
SET n += {description: 'Programa COBOL que limpia edcont para insertar los contratos que sin movimientos en el mes y con valuacion en cero. contratos que fueron insertados en edreper con ierror = 6 en la emision definitiva de los edos. de cuenta. despues de este programa se debe ejecutar el monica4. con parametro \'r\' (reproceso). ultima modif. monica rubio (asateck) se agrego parametros de la param tt2 para que no los borre de edcont y que los presente en sehipro con error 9. ultima modif. monica rubio (asateck) mzo-00 se agrego en sehipro el error 10 de clientes inactivos.. Pertenece a: PROBURSA, S.A. DE C.V. 25/MARZO/1996 /.', ingestion: 'auto', layer: 'program', name: 'ECB270M', nodeType: 'program', objective: 'LIMPIA EDCONT PARA INSERTAR LOS CONTRATOS QUE SIN MOVIMIENTOS EN EL MES Y CON VALUACION EN CERO. CONTRATOS QUE FUERON INSERTADOS EN EDREPER CON IERROR = 6 EN LA EMISION DEFINITIVA DE LOS EDOS. DE CUENTA. DESPUES DE ESTE PROGRAMA SE DEBE EJECUTAR EL MONICA4. CON PARAMETRO \'R\' (REPROCESO). ULTIMA MODIF. MONICA RUBIO (ASATECK) SE AGREGO PARAMETROS DE LA PARAM TT2 PARA QUE NO LOS BORRE DE EDCONT Y QUE LOS PRESENTE EN SEHIPRO CON ERROR 9. ULTIMA MODIF. MONICA RUBIO (ASATECK) MZO-00 SE AGREGO EN SEHIPRO EL ERROR 10 DE CLIENTES INACTIVOS.', reviewRequired: true, reviewSource: 'auto-ingestion', reviewStatus: 'pending_human_review', runId: 'e2e-20260621T203207Z-ecb220m-ecb230m-ecb240m-ecb250m-ecb255m-ecb270m-ecb280m-ecb290m-ecb300m-ecb320m', sourceFile: 'src/ECB270M.cbl', system: 'PROBURSA, S.A. DE C.V. 25/MARZO/1996 /', viewTag: 'cobol-program'};


MERGE (n:Program {name: 'ECB300M'})
SET n += {description: 'Programa COBOL que generar acuses de recibo, etiquetas y listado de clientes de banco. observaciones: parametros de entrada: f persona fisica o m persona moral, si se requiere impresion de etiquetas(0), si no se requiere (1) ultima modificacion: monica rubio (mrc-jul98) se agrego param tt2 para que no genere los acuses que caen dentro de esta iparam ultima modificacion: softtek (ecv1). agosto de 1999 redise¦o del acuse: se cambio la param tq2 por q05, se amplio la long. del archivo a 230, se agrego el iccosto en los cursores para obtener el nombre de la sucursal. ultima modificacion: monica rubio (asateck jun-00) se modifico el nombre de la empresa se cambio el titulo del reporte se cambio el orden del cursor por ipos. Pertenece a: NOV/96. /.', ingestion: 'auto', layer: 'program', name: 'ECB300M', nodeType: 'program', objective: 'GENERAR ACUSES DE RECIBO, ETIQUETAS Y LISTADO DE CLIENTES DE BANCO. OBSERVACIONES: PARAMETROS DE ENTRADA: F PERSONA FISICA O M PERSONA MORAL, SI SE REQUIERE IMPRESION DE ETIQUETAS(0), SI NO SE REQUIERE (1) ULTIMA MODIFICACION: MONICA RUBIO (MRC-JUL98) SE AGREGO PARAM TT2 PARA QUE NO GENERE LOS ACUSES QUE CAEN DENTRO DE ESTA IPARAM ULTIMA MODIFICACION: SOFTTEK (ECV1). AGOSTO DE 1999 REDISE¦O DEL ACUSE: SE CAMBIO LA PARAM TQ2 POR Q05, SE AMPLIO LA LONG. DEL ARCHIVO A 230, SE AGREGO EL ICCOSTO EN LOS CURSORES PARA OBTENER EL NOMBRE DE LA SUCURSAL. ULTIMA MODIFICACION: MONICA RUBIO (ASATECK JUN-00) SE MODIFICO EL NOMBRE DE LA EMPRESA SE CAMBIO EL TITULO DEL REPORTE SE CAMBIO EL ORDEN DEL CURSOR POR IPOS', reviewRequired: true, reviewSource: 'auto-ingestion', reviewStatus: 'pending_human_review', runId: 'e2e-20260621T203207Z-ecb220m-ecb230m-ecb240m-ecb250m-ecb255m-ecb270m-ecb280m-ecb290m-ecb300m-ecb320m', sourceFile: 'src/ECB300M.cbl', system: 'NOV/96. /', viewTag: 'cobol-program'};

MERGE (n:Program {name: 'ECB320M'})
SET n += {description: 'Programa COBOL que generar acuses de recibo, etiquetas y listado de clientes. observaciones: parametros de entrada: f persona fisica o m persona moral, si se requiere impresion de etiquetas(0), si no se requiere (1) ultima modificacion: monica rubio (abril-1999) se inhibio el proceso 080-imprime-acuse para que ya no imprima copia del acuse. ultima modificacion: asateck (monica rubio,mrc) feb-01 se excluye la impresion de los acuses que sean de los promotores 66, 355 y 215(ret) de casa de bolsa. se encuentran en la tabla param \'t99\'. ultima modificacion: asateck (monica rubio,mrc) abr-01 se excluye la impresion de los acuses que sean de la sucursal zpr con c.c. 3160.se ejecutaran en el programa ecb465m\'. se encuentran en la tabla param \'tz1\'. ultima modificacion: asateck (monica rubio,mrc) jul-02 se incluye la impresion de los acuses que sean de la sucursal zpr con c.c. 3160.(antes ecb465m). Pertenece a: JUL/97. /.', ingestion: 'auto', layer: 'program', name: 'ECB320M', nodeType: 'program', objective: 'GENERAR ACUSES DE RECIBO, ETIQUETAS Y LISTADO DE CLIENTES. OBSERVACIONES: PARAMETROS DE ENTRADA: F PERSONA FISICA O M PERSONA MORAL, SI SE REQUIERE IMPRESION DE ETIQUETAS(0), SI NO SE REQUIERE (1) ULTIMA MODIFICACION: MONICA RUBIO (ABRIL-1999) SE INHIBIO EL PROCESO 080-IMPRIME-ACUSE PARA QUE YA NO IMPRIMA COPIA DEL ACUSE. ULTIMA MODIFICACION: ASATECK (MONICA RUBIO,MRC) FEB-01 SE EXCLUYE LA IMPRESION DE LOS ACUSES QUE SEAN DE LOS PROMOTORES 66, 355 Y 215(RET) DE CASA DE BOLSA. SE ENCUENTRAN EN LA TABLA PARAM \'T99\'. ULTIMA MODIFICACION: ASATECK (MONICA RUBIO,MRC) ABR-01 SE EXCLUYE LA IMPRESION DE LOS ACUSES QUE SEAN DE LA SUCURSAL ZPR CON C.C. 3160.SE EJECUTARAN EN EL PROGRAMA ECB465M\'. SE ENCUENTRAN EN LA TABLA PARAM \'TZ1\'. ULTIMA MODIFICACION: ASATECK (MONICA RUBIO,MRC) JUL-02 SE INCLUYE LA IMPRESION DE LOS ACUSES QUE SEAN DE LA SUCURSAL ZPR CON C.C. 3160.(ANTES ECB465M)', reviewRequired: true, reviewSource: 'auto-ingestion', reviewStatus: 'pending_human_review', runId: 'e2e-20260621T203207Z-ecb220m-ecb230m-ecb240m-ecb250m-ecb255m-ecb270m-ecb280m-ecb290m-ecb300m-ecb320m', sourceFile: 'src/ECB320M.cbl', system: 'JUL/97. /', viewTag: 'cobol-program'};


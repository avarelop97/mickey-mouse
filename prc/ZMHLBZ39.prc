//            DISP=(NEW,CATLG,DELETE),
//            DCB=(DSORG=PS,RECFM=FB,LRECL=80,BLKSIZE=0),
//            UNIT=3390,
//            SPACE=(CYL,(2,1),RLSE)
//*
//ZMH986S1 DD DSN=MXCP.ZM.FIX.EBCM.REP39D01,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(LRECL=132,RECFM=FB,BLKSIZE=0,DSORG=PS),
//            UNIT=3390,
//            SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S2 DD DSN=MXCP.ZM.FIX.EBCM.REP39D02,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(LRECL=132,RECFM=FB,BLKSIZE=0,DSORG=PS),
//            UNIT=3390,
//            SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S3 DD DSN=MXCP.ZM.FIX.EBCM.REP39P03,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S4 DD DSN=MXCP.ZM.FIX.EBCM.REP39P04,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S5 DD DSN=MXCP.ZM.FIX.EBCM.REP39P05,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S6 DD DSN=MXCP.ZM.FIX.EBCM.REP39P06,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S7 DD DSN=MXCP.ZM.FIX.EBCM.REP39P07,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//ZMH986S8 DD DSN=MXCP.ZM.FIX.EBCM.REP39P08,
//           DISP=(NEW,CATLG,DELETE),
//           DCB=(LRECL=133,RECFM=FB,BLKSIZE=0,DSORG=PS),
//           UNIT=3390,
//           SPACE=(CYL,(4,2),RLSE)
//*
//SYSTSPRT DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SYSDBOUT DD SYSOUT=*
//SYSABOUT DD SYSOUT=*
//SYSUDUMP DD DUMMY
//SYSTSIN  DD DSN=ZIVA.ZME.CONTROL(ZHL39T06),DISP=SHR
//**********************************************************************
//*  OBJETIVO : SORTEAR ARCHIVO                                        *
//*  PROGRAMA : ICEMAN(TARJETA DE SORT ZHL31T6A)                       *
//**********************************************************************
//PJH39P6B EXEC PGM=ICEMAN,
//         COND=(4,LT)
//*
//SYSOUT   DD SYSOUT=*
//SORTIN   DD DSN=MXCP.ZM.FIX.EBCM.REP39D02,
//            DISP=SHR
//SORTOUT  DD DSN=MXCP.ZM.WKF.EBCM.REP39D03,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(LRECL=132,RECFM=FB,BLKSIZE=0,DSORG=PS),
//            UNIT=3390,
//            SPACE=(CYL,(4,2),RLSE)
//*
//SYSIN    DD DSN=ZIVA.ZME.CONTROL(ZHL39T6A),DISP=SHR
//*
//*******************************************************************
//* OBJETIVO : SEPARA LAS CUENTAS DE FIDEICOMISO DEL RESTO
//* PROGRAMA : ZM4CFID1
